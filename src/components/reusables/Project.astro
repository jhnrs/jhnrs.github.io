---
interface Props {
    id?: string;
    title: string;
    description: string;
    status?: string;
    features?: string[];
    section?: Section[];
    onlySummary?: boolean;
}

interface Section {
    title: string;
    feature: Feature[];
}

interface Feature {
    name?: string;
    description: string;
}

const project = Astro.props;
/* to create optional named sections for every feature provided */
---

<section id="projects" data-aos="fade-up">
    <!-- refinements here as it uses .item class which is inherited from Layout.astro. not wrapped from Card.astro -->

    <div class="item" data-aos="zoom-in">
        <h3 id={project.id}>{project.title}</h3>
        <p>{project.description}</p>
        <p><strong>Status: </strong>{project.status}</p>
        {
            project.onlySummary ? null : (
                <div>
                    <p>
                        <strong>Features: </strong>
                    </p>
                    {project.section && <p>{project.section}</p>}
                    {project.features && (
                        <ul>
                            {project.features.map((feature) => (
                                <li>{feature}</li>
                            ))}
                        </ul>
                    )}
                </div>
            )
        }
    </div>
</section>
