<style is:global>
    .card {
        margin: 0.5% auto;
        /* background: rgba(255, 255, 255, 0.05); */
        border-radius: 24px;
        /* box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3); */
        max-width: 80%;
        padding: 25px;
        justify-content: center;
        align-items: center;
    }

    .card li {
        margin: 6px 0px;
    }

    .card .item {

        border-left: 7px solid var(--accent);
        border-radius: 16px;
        padding: 10px 12px;
        margin: 5px;
        transition:
            ease 0.2s,
            box-shadow 0.2s,
            transform 0.3s;
    }
    .card .item:hover {
        border-radius: 16px;
        padding: 10px 16px; /* padding: top right bottom left */
        margin: 10px 0;
        box-shadow: 0 0 20px rgba(17, 185, 183, 0.719);
        transform: scale(1.01);
    }
    /* opposite of :hover is just use :not(:hover) */
    .card .item:not(:hover) {
        transition:
            ease 0.2s,
            box-shadow 0.2s,
            transform 0.3s;
    }
</style>

<div class="card">
    <slot />
</div>
