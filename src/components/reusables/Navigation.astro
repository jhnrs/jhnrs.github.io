---
<nav class="nav">
    <slot />
</nav>



<style>
    .dark-gradient {
        position: fixed;
        display: flex;
        flex-direction: row;
        top: 15px;
        left: 0;
        right: 0;
        width: fit-content;
        height: 500px;
        align-items: center;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
        background-color: linear-gradient(
                    180deg,
                    rgba(255, 255, 255, 0),
                    rgba(255, 255, 255, 0.5),
                    rgba(255, 255, 255, 1)
				);
    }
    .nav {
        display: flex;
        flex-direction: row;
        align-items: center;
        position: fixed;
        top: 15px;
        left: 0;
        right: 0;
        margin: 0px auto;
        padding: 5px;
        text-align: center;
        white-space: nowrap;
        overflow-x: auto;
        justify-content: space-evenly;
        gap: 12px;
        
        max-width: fit-content;
        
        z-index: 100;

        outline: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        background: rgba(46, 72, 129, 0.5);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5); /* for nav's shadows */
        backdrop-filter: blur(10px);
    
        opacity: 0;
        animation: fadeIntoView 1s ease forwards;
    }



    @keyframes fadeIntoView {
        from { opacity: 0; transform: scale(0.5) }
        to { opacity: 1; transform: scale(1) }
    }
</style>
